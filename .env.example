# Shopify
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01

# Mr. Shelby API
MR_SHELBY_API_URL=https://api.mrshelby.com.br
MR_SHELBY_API_KEY=your_api_key_here

# Database (JSON file — swap path as needed)
DB_PATH=./data/tracking.json

# Scheduler — how often to poll trackings (cron expression, default every 3 hours)
POLL_CRON=0 */3 * * *
